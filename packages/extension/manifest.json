{
  "manifest_version": 3,
  "name": "GazeKit — Eye Tracking for UX Research",
  "version": "0.1.0",
  "description": "Webcam-based eye tracking with heatmaps and gaze replay",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "storage", "offscreen", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/tracker.ts"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["http://localhost/*"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self'; connect-src * data: blob:; worker-src 'self' blob:;"
  },
  "sandbox": {
    "pages": ["src/calibration/sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["src/calibration/calibration.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
